# Required — Claude API key for extract + rank + global-rank + discovery curation.
ANTHROPIC_API_KEY=sk-ant-...

# Required — third-party transcript API (youtube-transcript.io). Sign up at
# https://www.youtube-transcript.io and copy the API token from your profile.
# Replaces yt-dlp captions + Groq Whisper fallback; episodes without a
# transcript here are skipped (no fallback path).
YOUTUBE_TRANSCRIPT_IO_TOKEN=...

# Required for real delivery; not used with --dry-run. Email goes out via Resend
# (https://resend.com). MAIL_FROM's domain must be verified in Resend or the API
# rejects the send. MAIL_FROM may be a bare address or "Display Name <addr@domain>".
RESEND_API_KEY=re_...
MAIL_FROM=you@yourdomain.com
MAIL_TO=you@yourdomain.com
