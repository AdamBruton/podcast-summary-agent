# Required
ANTHROPIC_API_KEY=sk-ant-...

# Optional — only needed for Whisper fallback when YouTube auto-captions are missing.
# Without this, episodes lacking captions will be logged and skipped.
GROQ_API_KEY=gsk_...

# Optional — path to a Netscape-format cookies.txt for yt-dlp. Needed when
# running on a non-residential IP (CI, cloud VM, container) because YouTube
# returns 403 to anonymous requests from those networks. Export from a
# logged-in browser ("Get cookies.txt LOCALLY" extension works). Path is
# resolved relative to project root if not absolute.
YT_COOKIES_FILE=cookies.txt

# Required for real delivery; not used with --dry-run.
SENDGRID_API_KEY=SG....
SENDGRID_FROM=you@yourdomain.com
SENDGRID_TO=you@yourdomain.com
