{
  "name": "podcast-summary-agent",
  "version": "0.1.0",
  "description": "Daily intelligence brief surfacing high-signal moments from tech/AI podcasts, biased by an editable interest profile.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "brief": "node src/cli.js",
    "brief:dry": "node src/cli.js --dry-run",
    "brief:episode": "node src/cli.js --episode",
    "resolve-channels": "node scripts/resolve-channels.js",
    "discover": "node scripts/discover.js",
    "discovery:audit": "node scripts/discovery-audit.js",
    "backup": "node scripts/backup-db.js",
    "upload-state-db": "node scripts/upload-state-db.js",
    "ingest-podcasts": "node scripts/ingest-podcasts.js",
    "web": "node src/web/server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "diff": "^9.0.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "resend": "^4.0.0",
    "rss-parser": "^3.13.0",
    "yaml": "^2.5.0"
  }
}
